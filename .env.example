# Polsia ES - Environment Variables Reference
# Copy this file to .env for local development

# ===== REQUIRED =====

# Node environment (development | production)
NODE_ENV=development

# Server port
PORT=3000

# PostgreSQL database connection string
# Production: Provided by Neon (auto-configured)
# Local: Use local PostgreSQL or docker-compose
DATABASE_URL=postgresql://localhost:5432/polsia_es

# Polsia platform API authentication
# Production: Auto-configured by Polsia
# Local: Get from Polsia dashboard
POLSIA_API_KEY=your_polsia_api_key_here
POLSIA_API_TOKEN=your_polsia_api_token_here

# Polsia analytics tracking
POLSIA_ANALYTICS_SLUG=hyper88os

# OpenAI API (via Polsia proxy)
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://polsia.com/ai/openai/v1

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_key_here

# Cloudflare R2 storage (via Polsia proxy)
POLSIA_R2_BASE_URL=https://polsia.com

# ===== OPTIONAL =====

# Application URL (for OAuth redirects, email links, OG tags)
# Production: Set to your custom domain
# APP_URL=https://polsia.es

# Session secret (auto-generated if not set)
# SESSION_SECRET=your_long_random_secret_here

# ===== LOCAL DEVELOPMENT ONLY =====

# For local development, you may want to disable secure cookies
# NODE_ENV=development

# Use local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/polsia_es_dev
